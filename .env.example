# Glass Box — optional LLM configuration. Copy to `.env` and fill in to run the
# live agentic mode. WITHOUT any of this, Glass Box runs its deterministic
# forensic engine (recall 1.0 / 0 hallucinations, fully offline). NEVER commit
# your real .env — it is gitignored.

# Pick the Investigator (Model A) and the Skeptic (Model B, ideally a DIFFERENT
# vendor). Format: vendor:model
GLASSBOX_INVESTIGATOR=groq:llama-3.3-70b-versatile
GLASSBOX_SKEPTIC=gemini:gemini-2.0-flash

# Free, no-credit-card API keys:
#   Groq    -> https://console.groq.com   (GROQ_API_KEY)
#   Gemini  -> https://aistudio.google.com/apikey   (GEMINI_API_KEY)
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# Also supported: anthropic:claude-... (ANTHROPIC_API_KEY),
# openai:gpt-4o (OPENAI_API_KEY), openrouter:... (OPENROUTER_API_KEY),
# ollama:llama3.1 (local, no key).
